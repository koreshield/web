{
  "name": "koreshield",
  "version": "0.3.8",
  "description": "JavaScript/TypeScript SDK for KoreShield LLM Security Platform - Enhanced with browser optimization, streaming, and framework integrations",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "browser": "dist/browser/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "build:node": "tsup",
    "dev": "tsup --watch",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "typecheck": "tsc --noEmit",
    "docs": "typedoc",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "llm",
    "security",
    "proxy",
    "openai",
    "anthropic",
    "ai-safety",
    "typescript",
    "javascript"
  ],
  "author": "KoreShield Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/koreshield/node-sdk.git"
  },
  "bugs": {
    "url": "https://github.com/koreshield/node-sdk/issues"
  },
  "homepage": "https://koreshield.com",
  "engines": {
    "node": ">=16.0.0"
  },
  "devDependencies": {
    "@angular/core": "^21.1.1",
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "@types/react": "^19.2.9",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.0.0",
    "jest": "^29.5.0",
    "jest-environment-jsdom": "^29.5.0",
    "rxjs": "^7.8.2",
    "ts-jest": "^29.1.0",
    "tsup": "^7.0.0",
    "typedoc": "^0.25.0",
    "typescript": "^5.0.0",
    "vue": "^3.5.27"
  },
  "dependencies": {
    "axios": "^1.6.0"
  },
  "peerDependencies": {
    "@angular/core": ">=12.0.0",
    "axios": "^1.6.0",
    "openai": "^4.0.0",
    "react": ">=16.8.0",
    "rxjs": ">=6.0.0",
    "vue": ">=3.0.0"
  },
  "peerDependenciesMeta": {
    "openai": {
      "optional": true
    },
    "react": {
      "optional": true
    },
    "vue": {
      "optional": true
    },
    "@angular/core": {
      "optional": true
    },
    "rxjs": {
      "optional": true
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ]
}
