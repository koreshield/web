# =============================================================================
# KoreShield Backend Configuration
# =============================================================================
#   SECURITY WARNING: Never commit this file to git!
#   This file contains sensitive credentials
# =============================================================================

# Database
DATABASE_URL=

# Redis
REDIS_URL=

# JWT Authentication (RS256)
JWT_PUBLIC_KEY=
JWT_ISSUER=koreshield-auth
JWT_AUDIENCE=koreshield-api

# JWT_PRIVATE_KEY should be set separately (not in git)
# Generate with: openssl genpkey -algorithm RSA -out private_key.pem -pkeyopt rsa_keygen_bits:2048
# JWT_PRIVATE_KEY=<paste private key here>
# For HS256 deployments only (do not combine with RSA keys):
# JWT_SECRET=<shared_signing_secret>

# LLM Provider API Keys
OPENAI_API_KEY=your_openai_key_here
ANTHROPIC_API_KEY=your_anthropic_key_here
DEEPSEEK_API_KEY=sk-do-better
GEMINI_API_KEY=your_gemini_key_here
AZURE_OPENAI_API_KEY=your_azure_key_here
AZURE_OPENAI_ENDPOINT=your_azure_endpoint_here

# Server Configuration
PORT=8000
HOST=0.0.0.0
ENVIRONMENT=production
KORESHIELD_APP_URL=https://koreshield.com
FRONTEND_BASE_URL=
APP_BASE_URL=
# ENABLED_PROVIDERS=openai,anthropic  # Optional filter for active providers
# KORESHIELD_EAGER_APP_INIT=true      # Set to false to delay provider startup

# CORS (comma-separated origins)
CORS_ORIGINS=
# COOKIE_SAMESITE=lax
# COOKIE_SECURE=true

# Polar Billing
POLAR_SERVER=sandbox
POLAR_ACCESS_TOKEN=
POLAR_WEBHOOK_SECRET=
POLAR_ORGANIZATION_SLUG=
POLAR_ORGANIZATION_ID=
POLAR_DEFAULT_CURRENCY=GBP
BILLING_INTERNAL_UNLIMITED_EMAILS=

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# Monitoring
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9090

# Notifications (Telegram)
TELEGRAM_ALERTS_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHANNEL_ID=
# TELEGRAM_MESSAGE_THREAD_ID=
TELEGRAM_HEALTH_DIGEST_ENABLED=true
TELEGRAM_HEALTH_DIGEST_INTERVAL_MINUTES=15
TELEGRAM_INCLUDE_ALERT_PAYLOAD=true

# Email (Resend)
RESEND_API_KEY=

# OAuth Configuration (GitHub & Google)
# Got credentials from:
#   GitHub: https://github.com/settings/developers -> OAuth Apps -> New OAuth App
#   Google: https://console.cloud.google.com/apis/credentials -> Create OAuth 2.0 Client ID
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
