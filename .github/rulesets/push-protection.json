{
	"name": "Push protection  -  block secrets and force pushes",
	"target": "push",
	"enforcement": "active",
	"rules": [
		{
			"type": "secret_scanning",
			"parameters": {}
		},
		{
			"type": "file_path_restriction",
			"parameters": {
				"restricted_file_paths": [
					".env",
					"prod.env",
					"*.pem",
					"*.key",
					"*.pfx",
					"*.p12",
					"id_rsa",
					"id_ed25519",
					".env.local",
					".env.production",
					"secrets.yml",
					"secrets.yaml"
				]
			}
		},
		{
			"type": "max_file_size",
			"parameters": {
				"max_file_size": 10240
			}
		}
	]
}