---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import ResearchBanner from "../components/ResearchBanner.astro";
import Footer from "../components/footer.astro";
import ArchivePanel from "../components/archivePanel.svelte";
import Newsletter from "../components/common/newsletter.astro";
import { getSortedPostsList } from "@utils/content";

const posts = await getSortedPostsList();
const sortedPosts = posts;

const allCategories = [
	...new Set(
		sortedPosts
			.map(
				(post) =>
					post.data.category?.title ||
					post.data.category,
			)
			.filter(Boolean),
	),
] as string[];
---

<Layout title="Koreshield - Security Intelligence">
	<Header />

	<main class="min-h-screen pt-24 md:pt-12 pb-24">
		<div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
			<div
				class="relative mb-24 pt-16 text-center max-w-4xl mx-auto"
			>
				<!-- Background Effects -->
				<div
					class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[350px] h-[350px] md:w-[600px] md:h-[600px] bg-electric-blue/20 rounded-full blur-[120px] -z-10 pointer-events-none"
				>
				</div>
				<div
					class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[250px] h-[250px] md:w-[400px] md:h-[400px] bg-cyber-purple/20 rounded-full blur-[100px] -z-10 pointer-events-none"
				>
				</div>

				<div
					class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-white/5 border border-white/10 text-sm text-electric-blue font-mono mb-8 animate-fade-in backdrop-blur-sm"
				>
					<span class="relative flex h-2 w-2">
						<span
							class="animate-ping absolute inline-flex h-full w-full rounded-full bg-electric-blue opacity-75"
						></span>
						<span
							class="relative inline-flex rounded-full h-2 w-2 bg-electric-blue"
						></span>
					</span>
					LATEST INTELLIGENCE
				</div>

				<h1
					class="text-4xl sm:text-5xl md:text-7xl font-bold mb-8 tracking-tight animate-fade-in font-sans leading-tight"
				>
					<span class="text-white"
						>Security Intelligence</span
					>
					<br />
					<span class="text-gradient"
						>For The AI Era</span
					>
				</h1>

				<p
					class="text-xl md:text-2xl text-gray-400 animate-fade-in max-w-2xl mx-auto leading-relaxed"
					style="animation-delay: 0.2s"
				>
					Deep dives into LLM security,
					adversarial attacks, and defense
					strategies for the modern enterprise.
				</p>

				<div
					class="mt-10 flex flex-wrap justify-center gap-4 animate-fade-in"
					style="animation-delay: 0.3s"
				>
					<a
						href="#latest-intelligence"
						class="group relative px-8 py-3 bg-electric-blue text-white rounded-lg font-semibold overflow-hidden transition-all hover:scale-105 hover:shadow-[0_0_40px_rgba(59,130,246,0.4)]"
					>
						<div
							class="absolute inset-0 bg-white/20 translate-y-full group-hover:translate-y-0 transition-transform duration-300"
						>
						</div>
						<span
							class="relative flex items-center gap-2"
						>
							Start Reading
							<svg
								xmlns="http://www.w3.org/2000/svg"
								class="h-4 w-4 transition-transform group-hover:translate-x-1"
								viewBox="0 0 20 20"
								fill="currentColor"
							>
								<path
									fill-rule="evenodd"
									d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z"
									clip-rule="evenodd"
								></path>
							</svg>
						</span>
					</a>
					<a
						href="https://koreshield.com"
						target="_blank"
						class="px-8 py-3 bg-white/5 border border-white/10 text-white rounded-lg font-semibold hover:bg-white/10 transition-colors backdrop-blur-sm"
					>
						Visit Platform
					</a>
				</div>
			</div>

			<div
				id="latest-intelligence"
				class="animate-fade-in"
				style="animation-delay: 0.4s"
			>
				<ArchivePanel
					sortedPosts={sortedPosts as any}
					categories={allCategories}
					client:load
				/>
			</div>

			<Newsletter />

			<ResearchBanner />

			<div class="mt-20 border-t border-white/5 pt-8">
				<Footer />
			</div>
		</div>
	</main>
</Layout>
