---
import { getSortedPostsList } from "@utils/content";
import GridLayout from "@layouts/grid.astro";
import BlogCard from "@components/BlogCard.astro";
import Breadcrumbs from "@components/common/breadcrumbs.astro";

export async function getStaticPaths() {
	const posts = await getSortedPostsList();

	// Get all unique tags
	const allTags = new Set<string>();
	posts.forEach((post) => {
		if (post.data.tags) {
			post.data.tags.forEach((tag) => allTags.add(tag));
		}
	});

	// Create paths for each tag
	const paths = Array.from(allTags).map((tag) => ({
		params: { tag: tag.toLowerCase().replace(/\s+/g, "-") },
		props: {
			tag,
			posts: posts.filter((post) =>
				post.data.tags?.includes(tag),
			),
		},
	}));

	return paths;
}

const { tag, posts } = Astro.props;
const title = `Posts tagged with "${tag}"`;
const description = `Browse all blog posts tagged with ${tag} on KoreShield.`;
---

<GridLayout title={title} description={description}>
	<div class="mb-8">
		<div class="mb-6 onload-animation-up">
			<Breadcrumbs
				items={[
					{ label: "Blog", href: "/archive" },
					{
						label: "Tags",
						href: "/archive?view=tags",
					},
					{ label: tag as string },
				]}
			/>
		</div>

		<div class="flex items-center gap-3 mb-4">
			<div
				class="px-3 py-1 bg-electric-blue/20 text-electric-blue rounded-full text-sm font-medium"
			>
				#{tag}
			</div>
			<span class="text-gray-400">
				{posts.length}
				{posts.length === 1 ? "post" : "posts"}
			</span>
		</div>

		<h1 class="text-3xl font-bold text-white mb-2">
			Posts tagged with "{tag}"
		</h1>
		<p class="text-gray-400">
			Discover all articles related to {tag} on KoreShield.
		</p>
	</div>

	{
		posts.length > 0 ? (
			<div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
				{posts.map((post) => (
					<BlogCard
						title={post.data.title}
						slug={post.id}
						publishedDate={
							post.data.published
						}
						coverImage={post.data.cover}
						readingTime={
							post.data.readingTime
						}
						tags={post.data.tags}
						category={
							post.data.category
								?.title ||
							post.data.category
						}
					/>
				))}
			</div>
		) : (
			<div class="text-center py-12">
				<div class="text-6xl mb-4">🏷️</div>
				<h2 class="text-2xl font-bold text-white mb-2">
					No posts found
				</h2>
				<p class="text-gray-400 mb-6">
					There are no posts tagged with "{tag}"
					yet.
				</p>
				<a
					href="/archive"
					class="inline-flex items-center gap-2 px-6 py-3 bg-electric-blue text-white rounded-lg hover:bg-electric-blue/80 transition-colors"
				>
					Browse All Posts
				</a>
			</div>
		)
	}
</GridLayout>
