Securing AI API integrations requires a comprehensive approach that goes beyond traditional API security. LLM APIs present unique challenges including prompt injection, data leakage, and resource exhaustion attacks. This guide covers essential best practices for protecting your AI API deployments.

## 1. Authentication and Authorization

### API Key Management

{% callout type="danger" %}
**Never hardcode API keys in your application code:**
{% /callout %}

```python
# Bad Practice
import openai
openai.api_key = "sk-abc123..."  # Hardcoded key

# Good Practice
import os
from koreshield import KoreShieldClient

# Load from environment variables
api_key = os.getenv("KORESHIELD_API_KEY")
if not api_key:
    raise ValueError("KORESHIELD_API_KEY environment variable not set")

client = KoreShieldClient(api_key=api_key)
```

### Key Rotation Strategy

{% callout type="tip" %}
**Implement regular key rotation:**
{% /callout %}

```python
from datetime import datetime, timedelta
import secrets

class APIKeyManager:
    def __init__(self, rotation_days: int = 90):
        self.rotation_days = rotation_days
        self.keys = {}  # Store keys with metadata
    
    def create_key(self, user_id: str, scopes: List[str]) -> str:
        """Create new API key with expiration."""
        key = f"sk_{secrets.token_urlsafe(32)}"
        
        self.keys[key] = {
            "user_id": user_id,
            "scopes": scopes,
            "created_at": datetime.utcnow(),
            "expires_at": datetime.utcnow() + timedelta(days=self.rotation_days),
            "last_used": None,
            "usage_count": 0
        }
        
        return key
    
    def validate_key(self, key: str, required_scope: str = None) -> bool:
        """Validate key and check expiration."""
        if key not in self.keys:
            return False
        
        key_data = self.keys[key]
        
        # Check expiration
        if datetime.utcnow() > key_data["expires_at"]:
            return False
        
        # Check scope if required
        if required_scope and required_scope not in key_data["scopes"]:
            return False
        
        # Update usage
        key_data["last_used"] = datetime.utcnow()
        key_data["usage_count"] += 1
        
        return True
    
    def rotate_key(self, old_key: str) -> str:
        """Rotate to new key while maintaining grace period."""
        if old_key not in self.keys:
            raise ValueError("Invalid key")
        
        old_data = self.keys[old_key]
        
        # Create new key
        new_key = self.create_key(
            user_id=old_data["user_id"],
            scopes=old_data["scopes"]
        )
        
        # Set grace period for old key
        self.keys[old_key]["expires_at"] = datetime.utcnow() + timedelta(days=7)
        
        return new_key

# Usage
key_mgr = APIKeyManager(rotation_days=90)

# Create key for user
api_key = key_mgr.create_key(
    user_id="user123",
    scopes=["llm:read", "llm:write"]
)

# Validate before use
if not key_mgr.validate_key(api_key, required_scope="llm:write"):
    raise PermissionError("Invalid or expired API key")
```

### Role-Based Access Control (RBAC)

Implement fine-grained permissions:

```python
from enum import Enum
from dataclasses import dataclass
from typing import List, Set

class Permission(Enum):
    READ_PROMPTS = "read:prompts"
    WRITE_PROMPTS = "write:prompts"
    READ_MODELS = "read:models"
    MANAGE_KEYS = "manage:keys"
    VIEW_ANALYTICS = "view:analytics"
    ADMIN = "admin:all"

@dataclass
class Role:
    name: str
    permissions: Set[Permission]

class RBACManager:
    def __init__(self):
        # Define roles
        self.roles = {
            "admin": Role("admin", {Permission.ADMIN}),
            "developer": Role("developer", {
                Permission.READ_PROMPTS,
                Permission.WRITE_PROMPTS,
                Permission.READ_MODELS,
                Permission.VIEW_ANALYTICS
            }),
            "analyst": Role("analyst", {
                Permission.READ_PROMPTS,
                Permission.VIEW_ANALYTICS
            }),
            "readonly": Role("readonly", {
                Permission.READ_PROMPTS,
                Permission.READ_MODELS
            })
        }
        
        self.user_roles = {}  # user_id -> role_name
    
    def assign_role(self, user_id: str, role_name: str):
        """Assign role to user."""
        if role_name not in self.roles:
            raise ValueError(f"Role {role_name} does not exist")
        
        self.user_roles[user_id] = role_name
    
    def check_permission(self, user_id: str, permission: Permission) -> bool:
        """Check if user has specific permission."""
        role_name = self.user_roles.get(user_id)
        if not role_name:
            return False
        
        role = self.roles[role_name]
        
        # Admin has all permissions
        if Permission.ADMIN in role.permissions:
            return True
        
        return permission in role.permissions
    
    def require_permission(self, user_id: str, permission: Permission):
        """Decorator to require specific permission."""
        if not self.check_permission(user_id, permission):
            raise PermissionError(
                f"User {user_id} lacks permission: {permission.value}"
            )

# Usage
rbac = RBACManager()

# Assign roles
rbac.assign_role("user123", "developer")
rbac.assign_role("user456", "analyst")

# Check permissions
@requires_permission(Permission.WRITE_PROMPTS)
async def create_llm_request(user_id: str, prompt: str):
    rbac.require_permission(user_id, Permission.WRITE_PROMPTS)
    # Proceed with LLM request
    ...
```

## 2. Rate Limiting and Throttling

### Token Bucket Algorithm

Implement sophisticated rate limiting:

```python
from collections import defaultdict
from dataclasses import dataclass
from datetime import datetime, timedelta
import asyncio

@dataclass
class TokenBucket:
    capacity: int
    tokens: float
    rate: float  # tokens per second
    last_update: datetime

class RateLimiter:
    def __init__(self):
        self.buckets = defaultdict(lambda: TokenBucket(
            capacity=100,
            tokens=100.0,
            rate=10.0,
            last_update=datetime.utcnow()
        ))
    
    def _refill_bucket(self, bucket: TokenBucket):
        """Refill bucket based on elapsed time."""
        now = datetime.utcnow()
        elapsed = (now - bucket.last_update).total_seconds()
        
        # Add tokens based on rate
        bucket.tokens = min(
            bucket.capacity,
            bucket.tokens + (elapsed * bucket.rate)
        )
        bucket.last_update = now
    
    async def acquire(
        self,
        user_id: str,
        tokens_needed: int = 1,
        timeout: float = 10.0
    ) -> bool:
        """
        Try to acquire tokens from bucket.
        Returns True if acquired, False if timeout.
        """
        bucket = self.buckets[user_id]
        start_time = datetime.utcnow()
        
        while True:
            self._refill_bucket(bucket)
            
            if bucket.tokens >= tokens_needed:
                bucket.tokens -= tokens_needed
                return True
            
            # Check timeout
            elapsed = (datetime.utcnow() - start_time).total_seconds()
            if elapsed >= timeout:
                return False
            
            # Wait before retry
            await asyncio.sleep(0.1)
    
    def get_remaining_tokens(self, user_id: str) -> int:
        """Get remaining tokens for user."""
        bucket = self.buckets[user_id]
        self._refill_bucket(bucket)
        return int(bucket.tokens)

# Usage
rate_limiter = RateLimiter()

async def handle_llm_request(user_id: str, prompt: str):
    # Calculate tokens needed (rough estimate)
    tokens_needed = len(prompt.split()) // 4
    
    # Try to acquire tokens
    if not await rate_limiter.acquire(user_id, tokens_needed, timeout=5.0):
        raise Exception("Rate limit exceeded. Please try again later.")
    
    # Proceed with request
    response = await llm.generate(prompt)
    return response
```

### Adaptive Rate Limiting

Adjust limits based on user behavior:

```python
class AdaptiveRateLimiter:
    def __init__(self):
        self.base_limits = {
            "free": {"requests_per_minute": 10, "tokens_per_day": 10000},
            "pro": {"requests_per_minute": 100, "tokens_per_day": 1000000},
            "enterprise": {"requests_per_minute": 1000, "tokens_per_day": 10000000}
        }
        
        self.user_stats = defaultdict(lambda: {
            "total_requests": 0,
            "failed_requests": 0,
            "average_response_time": 0.0,
            "trust_score": 1.0
        })
    
    def calculate_trust_score(self, user_id: str) -> float:
        """Calculate trust score based on behavior."""
        stats = self.user_stats[user_id]
        
        if stats["total_requests"] == 0:
            return 1.0
        
        # Factors affecting trust
        failure_rate = stats["failed_requests"] / stats["total_requests"]
        response_time_factor = min(stats["average_response_time"] / 1000.0, 1.0)
        
        # Calculate score (0.0 to 1.0)
        trust_score = 1.0 - (failure_rate * 0.5 + response_time_factor * 0.3)
        
        return max(0.0, min(1.0, trust_score))
    
    def get_adjusted_limit(self, user_id: str, tier: str) -> Dict:
        """Get rate limit adjusted by trust score."""
        base = self.base_limits[tier]
        trust_score = self.calculate_trust_score(user_id)
        
        # Adjust limits based on trust
        return {
            "requests_per_minute": int(base["requests_per_minute"] * trust_score),
            "tokens_per_day": int(base["tokens_per_day"] * trust_score)
        }
```

## 3. Input Validation and Sanitization

### Comprehensive Input Validation

```python
from typing import Dict, Optional
import re

class InputValidator:
    def __init__(self):
        self.max_prompt_length = 10000
        self.max_context_messages = 50
        self.allowed_models = ["gpt-4", "gpt-3.5-turbo", "claude-3-sonnet"]
        
        # Dangerous patterns
        self.blocked_patterns = [
            r"<script>",
            r"javascript:",
            r"onerror=",
            r"\bexec\b",
            r"\beval\b"
        ]
    
    def validate_prompt(self, prompt: str) -> Dict:
        """Validate user prompt."""
        errors = []
        
        # Length check
        if len(prompt) > self.max_prompt_length:
            errors.append(f"Prompt exceeds maximum length of {self.max_prompt_length}")
        
        if len(prompt) < 1:
            errors.append("Prompt cannot be empty")
        
        # Pattern check
        for pattern in self.blocked_patterns:
            if re.search(pattern, prompt, re.IGNORECASE):
                errors.append(f"Prompt contains blocked pattern: {pattern}")
        
        # Character check
        if not prompt.isprintable():
            errors.append("Prompt contains non-printable characters")
        
        return {
            "valid": len(errors) == 0,
            "errors": errors,
            "prompt_length": len(prompt)
        }
    
    def validate_request(self, request: Dict) -> Dict:
        """Validate complete API request."""
        errors = []
        
        # Check required fields
        if "model" not in request:
            errors.append("Missing required field: model")
        elif request["model"] not in self.allowed_models:
            errors.append(f"Invalid model: {request['model']}")
        
        if "messages" not in request:
            errors.append("Missing required field: messages")
        elif not isinstance(request["messages"], list):
            errors.append("Messages must be a list")
        elif len(request["messages"]) > self.max_context_messages:
            errors.append(f"Too many messages: {len(request['messages'])}")
        
        # Validate each message
        if "messages" in request:
            for i, msg in enumerate(request["messages"]):
                if "role" not in msg:
                    errors.append(f"Message {i} missing role")
                elif msg["role"] not in ["system", "user", "assistant"]:
                    errors.append(f"Message {i} has invalid role: {msg['role']}")
                
                if "content" not in msg:
                    errors.append(f"Message {i} missing content")
                else:
                    # Validate content
                    validation = self.validate_prompt(msg["content"])
                    if not validation["valid"]:
                        errors.extend([f"Message {i}: {e}" for e in validation["errors"]])
        
        # Validate optional parameters
        if "temperature" in request:
            temp = request["temperature"]
            if not isinstance(temp, (int, float)) or temp < 0 or temp > 2:
                errors.append("Temperature must be between 0 and 2")
        
        if "max_tokens" in request:
            max_tok = request["max_tokens"]
            if not isinstance(max_tok, int) or max_tok < 1 or max_tok > 4096:
                errors.append("max_tokens must be between 1 and 4096")
        
        return {
            "valid": len(errors) == 0,
            "errors": errors
        }

# Usage
validator = InputValidator()

async def handle_api_request(request: Dict):
    # Validate request
    validation = validator.validate_request(request)
    
    if not validation["valid"]:
        return {
            "error": "Invalid request",
            "details": validation["errors"]
        }, 400
    
    # Proceed with validated request
    ...
```

## 4. Monitoring and Logging

### Comprehensive Security Monitoring

```python
from dataclasses import dataclass
from datetime import datetime
from typing import Optional
import json

@dataclass
class SecurityEvent:
    timestamp: datetime
    event_type: str
    severity: str
    user_id: str
    details: Dict
    ip_address: Optional[str] = None
    user_agent: Optional[str] = None

class SecurityMonitor:
    def __init__(self):
        self.events = []
        self.alerts = []
    
    def log_event(self, event: SecurityEvent):
        """Log security event."""
        self.events.append(event)
        
        # Check for alert conditions
        if event.severity in ["high", "critical"]:
            self.trigger_alert(event)
        
        # Persist to database/file
        self._persist_event(event)
    
    def log_api_request(
        self,
        user_id: str,
        endpoint: str,
        method: str,
        status_code: int,
        response_time_ms: float,
        ip_address: str = None
    ):
        """Log API request for auditing."""
        event = SecurityEvent(
            timestamp=datetime.utcnow(),
            event_type="api_request",
            severity="info",
            user_id=user_id,
            details={
                "endpoint": endpoint,
                "method": method,
                "status_code": status_code,
                "response_time_ms": response_time_ms
            },
            ip_address=ip_address
        )
        
        self.log_event(event)
    
    def log_security_violation(
        self,
        user_id: str,
        violation_type: str,
        details: Dict
    ):
        """Log security violation."""
        event = SecurityEvent(
            timestamp=datetime.utcnow(),
            event_type="security_violation",
            severity="high",
            user_id=user_id,
            details={
                "violation_type": violation_type,
                **details
            }
        )
        
        self.log_event(event)
    
    def trigger_alert(self, event: SecurityEvent):
        """Trigger alert for high-severity events."""
        alert = {
            "timestamp": event.timestamp,
            "severity": event.severity,
            "message": f"Security event: {event.event_type}",
            "user_id": event.user_id,
            "details": event.details
        }
        
        self.alerts.append(alert)
        
        # Send to alerting system
        self._send_alert(alert)
    
    def _persist_event(self, event: SecurityEvent):
        """Persist event to storage."""
        # In production, write to database or log aggregation system
        log_entry = {
            "timestamp": event.timestamp.isoformat(),
            "event_type": event.event_type,
            "severity": event.severity,
            "user_id": event.user_id,
            "details": event.details,
            "ip_address": event.ip_address
        }
        
        print(json.dumps(log_entry))  # Replace with actual logging
    
    def _send_alert(self, alert: Dict):
        """Send alert to notification system."""
        # Implement webhook, email, Slack notification, etc.
        pass

# Usage
monitor = SecurityMonitor()

# Log API requests
monitor.log_api_request(
    user_id="user123",
    endpoint="/v1/chat/completions",
    method="POST",
    status_code=200,
    response_time_ms=245.3,
    ip_address="192.168.1.100"
)

# Log security violations
monitor.log_security_violation(
    user_id="user456",
    violation_type="prompt_injection",
    details={
        "prompt": "Ignore previous instructions...",
        "threat_level": "high",
        "confidence": 0.95
    }
)
```

