---
// Cookie Consent Banner Component
---

<div id="cookie-consent-banner" class="fixed bottom-0 left-0 right-0 z-50 bg-[var(--color-fd-card)] border-t border-[var(--color-fd-border)] p-4 shadow-lg transform translate-y-full transition-transform duration-300" style="display: none;">
  <div class="max-w-7xl mx-auto flex flex-col md:flex-row items-start md:items-center justify-between gap-4">
    <div class="flex-1">
      <h3 class="text-lg font-semibold text-white mb-2">Cookie Preferences</h3>
      <p class="text-gray-300 text-sm leading-relaxed">
        We use cookies to enhance your experience, analyze site traffic, and personalize content. By continuing to use our site, you consent to our use of cookies.
        <a href="/cookie-policy" class="text-electric-blue hover:underline ml-1">Learn more</a>
      </p>
    </div>

    <div class="flex flex-col sm:flex-row gap-2 shrink-0">
      <button
        id="accept-all-cookies"
        class="px-4 py-2 bg-electric-blue text-white text-sm font-medium rounded-lg hover:bg-electric-blue/80 transition-colors focus:outline-none focus:ring-2 focus:ring-electric-blue focus:ring-offset-2 focus:ring-offset-[var(--color-fd-card)]"
      >
        Accept All
      </button>

      <button
        id="reject-cookies"
        class="px-4 py-2 bg-transparent border border-[var(--color-fd-border)] text-gray-300 text-sm font-medium rounded-lg hover:bg-[var(--color-fd-secondary)] transition-colors focus:outline-none focus:ring-2 focus:ring-gray-400 focus:ring-offset-2 focus:ring-offset-[var(--color-fd-card)]"
      >
        Reject Non-Essential
      </button>

      <button
        id="customize-cookies"
        class="px-4 py-2 bg-transparent border border-[var(--color-fd-border)] text-gray-300 text-sm font-medium rounded-lg hover:bg-[var(--color-fd-secondary)] transition-colors focus:outline-none focus:ring-2 focus:ring-gray-400 focus:ring-offset-2 focus:ring-offset-[var(--color-fd-card)]"
      >
        Customize
      </button>
    </div>
  </div>
</div>

<!-- Cookie Customization Modal -->
<div id="cookie-modal" class="fixed inset-0 z-50 flex items-center justify-center p-4 bg-black/50 opacity-0 pointer-events-none transition-opacity duration-300" style="display: none;">
  <div class="bg-[var(--color-fd-card)] border border-[var(--color-fd-border)] rounded-xl shadow-2xl max-w-md w-full max-h-[90vh] overflow-y-auto">
    <div class="p-6">
      <div class="flex items-center justify-between mb-4">
        <h3 class="text-xl font-semibold text-white">Cookie Settings</h3>
        <button id="close-cookie-modal" class="text-gray-400 hover:text-white transition-colors">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
          </svg>
        </button>
      </div>

      <div class="space-y-4">
        <!-- Essential Cookies -->
        <div class="border border-[var(--color-fd-border)] rounded-lg p-4">
          <div class="flex items-center justify-between mb-2">
            <h4 class="font-medium text-white">Essential Cookies</h4>
            <span class="text-xs bg-electric-blue/20 text-electric-blue px-2 py-1 rounded">Required</span>
          </div>
          <p class="text-sm text-gray-300">These cookies are necessary for the website to function and cannot be disabled.</p>
          <div class="mt-2">
            <input type="checkbox" id="essential-cookies" checked disabled class="rounded border-[var(--color-fd-border)] bg-[var(--color-fd-secondary)]">
            <label for="essential-cookies" class="ml-2 text-sm text-gray-300">Always enabled</label>
          </div>
        </div>

        <!-- Analytics Cookies -->
        <div class="border border-[var(--color-fd-border)] rounded-lg p-4">
          <div class="flex items-center justify-between mb-2">
            <h4 class="font-medium text-white">Analytics Cookies</h4>
            <label class="relative inline-flex items-center cursor-pointer">
              <input type="checkbox" id="analytics-cookies" class="sr-only peer">
              <div class="w-11 h-6 bg-gray-600 peer-focus:outline-none peer-focus:ring-4 peer-focus:ring-electric-blue/25 rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-electric-blue"></div>
            </label>
          </div>
          <p class="text-sm text-gray-300">Help us understand how visitors interact with our website to improve user experience.</p>
        </div>

        <!-- Marketing Cookies -->
        <div class="border border-[var(--color-fd-border)] rounded-lg p-4">
          <div class="flex items-center justify-between mb-2">
            <h4 class="font-medium text-white">Marketing Cookies</h4>
            <label class="relative inline-flex items-center cursor-pointer">
              <input type="checkbox" id="marketing-cookies" class="sr-only peer">
              <div class="w-11 h-6 bg-gray-600 peer-focus:outline-none peer-focus:ring-4 peer-focus:ring-electric-blue/25 rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-electric-blue"></div>
            </label>
          </div>
          <p class="text-sm text-gray-300">Used to deliver personalized advertisements and track campaign effectiveness.</p>
        </div>
      </div>

      <div class="flex gap-3 mt-6">
        <button
          id="save-cookie-preferences"
          class="flex-1 px-4 py-2 bg-electric-blue text-white text-sm font-medium rounded-lg hover:bg-electric-blue/80 transition-colors focus:outline-none focus:ring-2 focus:ring-electric-blue focus:ring-offset-2 focus:ring-offset-[var(--color-fd-card)]"
        >
          Save Preferences
        </button>
        <button
          id="accept-all-modal"
          class="flex-1 px-4 py-2 bg-transparent border border-[var(--color-fd-border)] text-gray-300 text-sm font-medium rounded-lg hover:bg-[var(--color-fd-secondary)] transition-colors focus:outline-none focus:ring-2 focus:ring-gray-400 focus:ring-offset-2 focus:ring-offset-[var(--color-fd-card)]"
        >
          Accept All
        </button>
      </div>
    </div>
  </div>
</div>

<script>
  class CookieConsent {
    constructor() {
      this.banner = document.getElementById('cookie-consent-banner');
      this.modal = document.getElementById('cookie-modal');
      this.init();
    }

    init() {
      // Check if user has already made a choice
      const consent = this.getCookieConsent();

      if (!consent) {
        // Show banner after a short delay
        setTimeout(() => {
          this.showBanner();
        }, 1000);
      }

      this.bindEvents();
    }

    showBanner() {
      this.banner.style.display = 'block';
      setTimeout(() => {
        this.banner.classList.remove('translate-y-full');
      }, 100);
    }

    hideBanner() {
      this.banner.classList.add('translate-y-full');
      setTimeout(() => {
        this.banner.style.display = 'none';
      }, 300);
    }

    showModal() {
      this.modal.style.display = 'flex';
      setTimeout(() => {
        this.modal.classList.remove('opacity-0', 'pointer-events-none');
      }, 100);
    }

    hideModal() {
      this.modal.classList.add('opacity-0', 'pointer-events-none');
      setTimeout(() => {
        this.modal.style.display = 'none';
      }, 300);
    }

    bindEvents() {
      // Banner buttons
      document.getElementById('accept-all-cookies')?.addEventListener('click', () => {
        this.setCookieConsent('all');
        this.hideBanner();
      });

      document.getElementById('reject-cookies')?.addEventListener('click', () => {
        this.setCookieConsent('essential');
        this.hideBanner();
      });

      document.getElementById('customize-cookies')?.addEventListener('click', () => {
        this.showModal();
      });

      // Modal buttons
      document.getElementById('close-cookie-modal')?.addEventListener('click', () => {
        this.hideModal();
      });

      document.getElementById('save-cookie-preferences')?.addEventListener('click', () => {
        const analytics = document.getElementById('analytics-cookies').checked;
        const marketing = document.getElementById('marketing-cookies').checked;

        let consent = 'essential';
        if (analytics && marketing) {
          consent = 'all';
        } else if (analytics || marketing) {
          consent = 'partial';
        }

        this.setCookieConsent(consent, { analytics, marketing });
        this.hideModal();
        this.hideBanner();
      });

      document.getElementById('accept-all-modal')?.addEventListener('click', () => {
        document.getElementById('analytics-cookies').checked = true;
        document.getElementById('marketing-cookies').checked = true;
        this.setCookieConsent('all');
        this.hideModal();
        this.hideBanner();
      });

      // Close modal when clicking outside
      this.modal?.addEventListener('click', (e) => {
        if (e.target === this.modal) {
          this.hideModal();
        }
      });
    }

    getCookieConsent() {
      return localStorage.getItem('koreshield-cookie-consent');
    }

    setCookieConsent(level, preferences = {}) {
      const consent = {
        level,
        timestamp: new Date().toISOString(),
        ...preferences
      };

      localStorage.setItem('koreshield-cookie-consent', JSON.stringify(consent));

      // Here you would typically initialize/disable tracking based on consent
      this.applyConsent(level, preferences);
    }

    applyConsent(level, preferences) {
      // Disable/enable analytics based on consent
      if (level === 'essential') {
        // Disable all non-essential tracking
        this.disableAnalytics();
        this.disableMarketing();
      } else if (level === 'all') {
        // Enable all tracking
        this.enableAnalytics();
        this.enableMarketing();
      } else if (level === 'partial') {
        // Enable based on preferences
        if (preferences.analytics) {
          this.enableAnalytics();
        } else {
          this.disableAnalytics();
        }

        if (preferences.marketing) {
          this.enableMarketing();
        } else {
          this.disableMarketing();
        }
      }
    }

    enableAnalytics() {
      // Enable Google Analytics, Vercel Analytics, etc.
      console.log('Analytics enabled');
    }

    disableAnalytics() {
      // Disable Google Analytics, Vercel Analytics, etc.
      console.log('Analytics disabled');
    }

    enableMarketing() {
      // Enable marketing cookies and tracking
      console.log('Marketing enabled');
    }

    disableMarketing() {
      // Disable marketing cookies and tracking
      console.log('Marketing disabled');
    }
  }

  // Initialize cookie consent when DOM is loaded
  document.addEventListener('DOMContentLoaded', () => {
    new CookieConsent();
  });
</script>