---
interface Props {
  count?: number;
}

const { count = 1 } = Astro.props;
---

{Array.from({ length: count }).map(() => (
  <div class="block relative overflow-hidden rounded-2xl bg-[var(--color-fd-card)] border border-[var(--color-fd-border)] h-full flex flex-col shadow-lg shadow-black/20 animate-pulse">
    <!-- Image skeleton -->
    <div class="aspect-video w-full bg-gray-700/50"></div>

    <div class="p-6 flex flex-col flex-grow">
      <!-- Date and reading time skeleton -->
      <div class="mb-4 flex items-center gap-4">
        <div class="flex items-center gap-2">
          <div class="h-1.5 w-1.5 rounded-full bg-gray-600"></div>
          <div class="h-3 w-20 bg-gray-600 rounded"></div>
        </div>
        <div class="flex items-center gap-2">
          <div class="h-3 w-3 bg-gray-600 rounded"></div>
          <div class="h-3 w-16 bg-gray-600 rounded"></div>
        </div>
      </div>

      <!-- Title skeleton -->
      <div class="mb-3">
        <div class="h-6 bg-gray-600 rounded w-3/4 mb-2"></div>
        <div class="h-6 bg-gray-600 rounded w-1/2"></div>
      </div>

      <!-- Tags skeleton -->
      <div class="mb-4 flex flex-wrap gap-2">
        <div class="h-6 w-16 bg-gray-600 rounded-md"></div>
        <div class="h-6 w-12 bg-gray-600 rounded-md"></div>
        <div class="h-6 w-14 bg-gray-600 rounded-md"></div>
      </div>

      <!-- Read more skeleton -->
      <div class="mt-auto pt-4 flex items-center">
        <div class="h-4 w-24 bg-gray-600 rounded"></div>
        <div class="h-4 w-4 bg-gray-600 rounded ml-1"></div>
      </div>
    </div>
  </div>
))}