---
interface Props {
  title: string;
  slug: string;
  publishedDate: Date | string;
  coverImage?: string;
  readingTime?: number;
  tags?: string[];
  category?: string;
}

const { title, slug, publishedDate, coverImage, readingTime, tags, category } =
  Astro.props;

// Handle potential Keystatic image object or string
const imageSrc = typeof coverImage === "string" ? coverImage : null;
// Note: Keystatic image is usually just a string path if configured with 'publicPath'

const formattedDate = new Date(publishedDate).toLocaleDateString("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
});
---

<div
  class="group relative overflow-hidden rounded-2xl bg-[var(--color-fd-card)] border border-[var(--color-fd-border)] hover:border-electric-blue/30 transition-all duration-500 h-full flex flex-col shadow-lg shadow-black/20 hover:shadow-[0_0_30px_rgba(59,130,246,0.15)] hover:-translate-y-1"
>
  {
    imageSrc && (
      <a
        href={`/posts/${slug}`}
        class="block aspect-video w-full overflow-hidden border-b border-white/5 relative z-10"
      >
        <img
          src={imageSrc}
          alt={title}
          class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
        />
      </a>
    )
  }

  <div class="p-6 flex flex-col flex-grow relative z-10">
    <div class="mb-4 flex items-center gap-4">
      <div class="flex items-center gap-2">
        <span
          class="inline-block h-1.5 w-1.5 rounded-full bg-electric-blue shadow-[0_0_8px_rgba(59,130,246,0.8)]"
        ></span>
        <span class="text-xs font-mono text-gray-400 uppercase tracking-wider"
          >{formattedDate}</span
        >
      </div>
      {
        readingTime && (
          <div class="flex items-center gap-2">
            <svg
              class="w-3 h-3 text-gray-400"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"
              />
            </svg>
            <span class="text-xs font-mono text-gray-400 uppercase tracking-wider">
              {readingTime} min read
            </span>
          </div>
        )
      }
    </div>

    <h3
      class="text-xl font-bold text-white mb-3 line-clamp-2 leading-tight group-hover:text-electric-blue transition-colors"
    >
      <a href={`/posts/${slug}`} class="focus:outline-none">
        <span class="absolute inset-0" aria-hidden="true"></span>
        {title}
      </a>
    </h3>

    <!-- Tags and Category -->
    {
      (tags || category) && (
        <div class="mb-4 flex flex-wrap gap-2 relative z-20">
          {category && (
            <a
              href={`/categories/${category.toLowerCase().replace(/\s+/g, "-")}`}
              class="inline-flex items-center gap-1 px-2 py-1 bg-cyber-purple/20 text-cyber-purple text-xs font-medium rounded-md hover:bg-cyber-purple/30 transition-colors"
            >
              📁 {category}
            </a>
          )}
          {tags &&
            tags.slice(0, 3).map((tag) => (
              <a
                href={`/tags/${tag.toLowerCase().replace(/\s+/g, "-")}`}
                class="inline-flex items-center gap-1 px-2 py-1 bg-electric-blue/20 text-electric-blue text-xs font-medium rounded-md hover:bg-electric-blue/30 transition-colors"
              >
                #{tag}
              </a>
            ))}
          {tags && tags.length > 3 && (
            <span class="text-xs text-gray-500 px-2 py-1">
              +{tags.length - 3} more
            </span>
          )}
        </div>
      )
    }

    <div
      class="mt-auto pt-4 flex items-center text-electric-blue text-sm font-medium opacity-0 -translate-x-2 group-hover:opacity-100 group-hover:translate-x-0 transition-all duration-300"
    >
      Read Analysis
      <svg
        xmlns="http://www.w3.org/2000/svg"
        class="h-4 w-4 ml-1"
        viewBox="0 0 20 20"
        fill="currentColor"
      >
        <path
          fill-rule="evenodd"
          d="M12.293 5.293a1 1 0 011.414 0l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-2.293-2.293a1 1 0 010-1.414z"
          clip-rule="evenodd"></path>
      </svg>
    </div>
  </div>
</div>
