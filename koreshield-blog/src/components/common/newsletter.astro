---
import { Icon } from "astro-icon/components";
---

<div
    class="relative overflow-hidden rounded-2xl bg-[#0f1623] border border-electric-blue/20 p-8 md:p-12 mb-16 group"
>
    <!-- Background Effects -->
    <div
        class="absolute top-0 right-0 w-64 h-64 bg-electric-blue/5 rounded-full blur-[80px] -translate-y-1/2 translate-x-1/2 pointer-events-none group-hover:bg-electric-blue/10 transition-colors duration-700"
    >
    </div>
    <div
        class="absolute bottom-0 left-0 w-48 h-48 bg-cyber-purple/5 rounded-full blur-[60px] translate-y-1/2 -translate-x-1/2 pointer-events-none group-hover:bg-cyber-purple/10 transition-colors duration-700"
    >
    </div>

    <div
        class="relative z-10 flex flex-col md:flex-row gap-8 items-center justify-between"
    >
        <div class="max-w-lg">
            <div
                class="flex items-center gap-2 mb-3 text-electric-blue font-mono text-sm tracking-wider"
            >
                <Icon
                    name="material-symbols:mark-email-unread-outline"
                    class="w-5 h-5"
                />
                <span>STAY SECURE</span>
            </div>
            <h3 class="text-2xl font-bold text-white mb-3">
                Get the Latest LLM Security Intelligence
            </h3>
            <p class="text-gray-400 leading-relaxed">
                Join our security researchers and receive weekly updates on
                prompt injection threats, jailbreak analysis, and defense
                strategies.
            </p>
        </div>

        <form
            class="w-full md:w-auto flex flex-col gap-3"
            onsubmit="event.preventDefault(); console.log('Newsletter signup:', this.email.value); this.reset(); alert('Thanks for subscribing!');"
        >
            <div class="relative group/input">
                <div
                    class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none text-gray-500 group-focus-within/input:text-electric-blue transition-colors"
                >
                    <Icon
                        name="material-symbols:mail-outline"
                        class="w-5 h-5"
                    />
                </div>
                <input
                    type="email"
                    name="email"
                    placeholder="Enter your work email"
                    required
                    class="w-full pl-10 pr-4 py-3 bg-black/20 border border-white/10 rounded-lg text-white placeholder-gray-500 focus:outline-none focus:border-electric-blue/50 focus:ring-1 focus:ring-electric-blue/50 transition-all font-mono text-sm"
                />
            </div>
            <button
                type="submit"
                class="w-full py-3 px-6 bg-electric-blue text-white rounded-lg font-bold hover:bg-electric-blue/90 transition-all hover:scale-[1.02] active:scale-[0.98] shadow-lg shadow-electric-blue/20 flex items-center justify-center gap-2"
            >
                <span>Subscribe via Email</span>
                <Icon
                    name="material-symbols:arrow-right-alt-rounded"
                    class="w-5 h-5"
                />
            </button>
            <p class="text-xs text-center text-gray-600">
                Start your <span class="text-gray-500">Free Subscription</span> today.
                No spam.
            </p>
        </form>
    </div>
</div>
