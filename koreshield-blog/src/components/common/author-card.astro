---
import { Icon } from "astro-icon/components";

interface Props {
  author: {
    name: string;
    email?: string;
    bio: string;
    avatar?: string;
    social?: {
      twitter?: string;
      github?: string;
      linkedin?: string;
    };
    role?: string;
    company?: string;
    location?: string;
  };
}

const { author } = Astro.props;
---

<div class="author-card glass-panel border border-white/10 rounded-2xl p-6 md:p-8 mt-12 mb-8 hover:border-electric-blue/30 transition-all duration-300">
  <div class="flex flex-col md:flex-row gap-6">
    <!-- Avatar -->
    <div class="flex-shrink-0">
      {author.avatar ? (
        <img 
          src={author.avatar} 
          alt={author.name}
          class="w-20 h-20 md:w-24 md:h-24 rounded-full object-cover border-2 border-electric-blue/30"
        />
      ) : (
        <div class="w-20 h-20 md:w-24 md:h-24 rounded-full bg-gradient-to-br from-electric-blue/20 to-cyber-purple/20 flex items-center justify-center border-2 border-electric-blue/30">
          <Icon name="material-symbols:person" class="w-12 h-12 text-electric-blue" />
        </div>
      )}
    </div>

    <!-- Author Info -->
    <div class="flex-grow">
      <div class="mb-3">
        <h3 class="text-2xl font-bold text-white mb-1">{author.name}</h3>
        {author.role && (
          <p class="text-sm text-electric-blue font-medium">
            {author.role}
            {author.company && <span class="text-gray-400"> at {author.company}</span>}
          </p>
        )}
        {author.location && (
          <p class="text-xs text-gray-500 mt-1 flex items-center gap-1">
            <Icon name="material-symbols:location-on" class="w-3 h-3" />
            {author.location}
          </p>
        )}
      </div>

      <p class="text-gray-400 leading-relaxed mb-4">
        {author.bio}
      </p>

      <!-- Social Links -->
      {author.social && Object.keys(author.social).length > 0 && (
        <div class="flex gap-3">
          {author.social.twitter && (
            <a 
              href={author.social.twitter}
              target="_blank"
              rel="noopener noreferrer"
              class="w-9 h-9 rounded-lg bg-white/5 hover:bg-electric-blue/20 border border-white/10 hover:border-electric-blue/30 flex items-center justify-center transition-all duration-300 hover:-translate-y-0.5"
              aria-label="Twitter"
            >
              <Icon name="fa6-brands:x-twitter" class="w-4 h-4 text-gray-400 hover:text-electric-blue" />
            </a>
          )}
          {author.social.github && (
            <a 
              href={author.social.github}
              target="_blank"
              rel="noopener noreferrer"
              class="w-9 h-9 rounded-lg bg-white/5 hover:bg-electric-blue/20 border border-white/10 hover:border-electric-blue/30 flex items-center justify-center transition-all duration-300 hover:-translate-y-0.5"
              aria-label="GitHub"
            >
              <Icon name="fa6-brands:github" class="w-4 h-4 text-gray-400 hover:text-electric-blue" />
            </a>
          )}
          {author.social.linkedin && (
            <a 
              href={author.social.linkedin}
              target="_blank"
              rel="noopener noreferrer"
              class="w-9 h-9 rounded-lg bg-white/5 hover:bg-electric-blue/20 border border-white/10 hover:border-electric-blue/30 flex items-center justify-center transition-all duration-300 hover:-translate-y-0.5"
              aria-label="LinkedIn"
            >
              <Icon name="fa6-brands:linkedin" class="w-4 h-4 text-gray-400 hover:text-electric-blue" />
            </a>
          )}
          {author.email && (
            <a 
              href={`mailto:${author.email}`}
              class="w-9 h-9 rounded-lg bg-white/5 hover:bg-electric-blue/20 border border-white/10 hover:border-electric-blue/30 flex items-center justify-center transition-all duration-300 hover:-translate-y-0.5"
              aria-label="Email"
            >
              <Icon name="material-symbols:mail-outline" class="w-4 h-4 text-gray-400 hover:text-electric-blue" />
            </a>
          )}
        </div>
      )}
    </div>
  </div>

  <!-- Decorative corner accent -->
  <div class="absolute top-0 right-0 w-32 h-32 bg-gradient-to-br from-electric-blue/5 to-transparent rounded-2xl pointer-events-none"></div>
</div>
