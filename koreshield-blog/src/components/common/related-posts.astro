---
import { getSortedPostsList } from "@utils/content";
import BlogCard from "../BlogCard.astro";

interface Props {
	currentPostId: string;
	currentTags: string[];
	currentCategory?: string;
	limit?: number;
}

const { currentPostId, currentTags, currentCategory, limit = 3 } = Astro.props;

const allPosts = await getSortedPostsList();

// Filter out current post and find related posts
const relatedPosts = allPosts
	.filter((post) => post.id !== currentPostId)
	.map((post) => {
		let score = 0;

		// Boost score for same category
		if (currentCategory && post.data.category === currentCategory) {
			score += 3;
		}

		// Boost score for shared tags
		if (post.data.tags) {
			const sharedTags = post.data.tags.filter((tag) =>
				currentTags.includes(tag),
			);
			score += sharedTags.length * 2;
		}

		return { ...post, relevanceScore: score };
	})
	.filter((post) => post.relevanceScore > 0)
	.sort((a, b) => b.relevanceScore - a.relevanceScore)
	.slice(0, limit);

if (relatedPosts.length === 0) {
	// Fallback: show recent posts if no related posts found
	const fallbackPosts = allPosts
		.filter((post) => post.id !== currentPostId)
		.slice(0, limit)
		.map((post) => ({ ...post, relevanceScore: 0 }));
	relatedPosts.push(...fallbackPosts);
}
---

{
	relatedPosts.length > 0 && (
		<div class="mt-12 mb-8">
			<h2 class="text-2xl font-bold text-white mb-6 flex items-center gap-3">
				<svg
					class="w-6 h-6 text-electric-blue"
					fill="none"
					stroke="currentColor"
					viewBox="0 0 24 24"
				>
					<path
						stroke-linecap="round"
						stroke-linejoin="round"
						stroke-width="2"
						d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"
					/>
				</svg>
				Related Articles
			</h2>

			<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
				{relatedPosts.map((post) => (
					<BlogCard
						title={post.data.title}
						slug={post.id}
						publishedDate={
							post.data.published
						}
						coverImage={post.data.cover}
						readingTime={post.readingTime}
					/>
				))}
			</div>
		</div>
	)
}
