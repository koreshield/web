---
import { Icon } from "astro-icon/components";

import { type NavbarLink } from "@/types/config";
import { url } from "@utils/url";

interface Props {
    link: NavbarLink;
    class?: string;
}

const { link, class: className } = Astro.props;
---

<div class:list={["nav-link-container", className]}>
    <a
        aria-label={link.name}
        href={link.external ? link.url : url(link.url)}
        target={link.external ? "_blank" : null}
        class:list={[
            "block font-bold px-4 py-2 rounded-full transition-all duration-300 nav-link-item active:scale-95",
            Astro.url.pathname === link.url ||
            (link.url !== "/" && Astro.url.pathname.startsWith(link.url))
                ? "bg-[var(--primary)]/10 text-[var(--primary)]"
                : "text-neutral-600 dark:text-neutral-400 hover:bg-black/5 dark:hover:bg-white/10 hover:text-[var(--primary)] pointer-events-auto",
        ]}
        data-link-name={link.name}
    >
        <div class="flex items-center">
            {
                link.icon && (
                    <Icon
                        name={link.icon}
                        class="text-[1.1rem] nav-link-icon"
                    />
                )
            }
            <span class="nav-link-text ml-2 hidden lg:inline">{link.name}</span>
            {
                link.external && (
                    <Icon
                        name="fa6-solid:arrow-up-right-from-square"
                        class="text-[0.75rem] transition -translate-y-[1px] ml-1 opacity-50"
                    />
                )
            }
        </div>
    </a>
</div>

<style>
    .nav-link-container {
        @apply relative flex items-center justify-center;
    }

    /* Small screens: Icon only */
    @media (max-width: 1279px) {
        .nav-link-item {
            @apply w-10 h-10 px-0 flex items-center justify-center rounded-lg;
        }

        .nav-link-text {
            @apply hidden;
        }

        .nav-link-icon {
            @apply ml-0 text-xl;
        }
    }

    /* Large screens: Icon + Text */
    @media (min-width: 1280px) {
        .nav-link-text {
            @apply inline;
        }
    }
</style>
