---
interface Props {
	scrolled?: boolean;
}

const { scrolled = false } = Astro.props;
---

<header
	class={`fixed top-0 left-0 right-0 z-50 transition-all duration-300 ${
		scrolled
			? "bg-deep-navy/80 backdrop-blur-xl border-b border-white/5 py-4 supports-[backdrop-filter]:bg-deep-navy/60"
			: "bg-deep-navy/90 backdrop-blur-md md:bg-transparent border-b border-white/5 md:border-transparent py-4 md:py-6"
	}`}
>
	<div class="max-w-7xl mx-auto px-6 flex items-center justify-between">
		<!-- Logo -->
		<a href="/" class="flex items-center gap-3 group">
			<div class="relative">
				<div
					class="absolute -inset-1 bg-electric-blue/20 rounded-full blur-sm opacity-0 group-hover:opacity-100 transition-opacity duration-500"
				>
				</div>
				<img
					src="/logo/light/SVG/White.svg"
					alt="KoreShield Logo"
					class={`${scrolled ? "w-8" : "w-10"} transition-all relative z-10`}
				/>
			</div>
			<span
				class="font-bold text-lg tracking-tight text-white/90 group-hover:text-white transition-colors"
			>
				KoreShield
			</span>
		</a>

		<!-- Desktop Navigation -->
		<div
			class="hidden md:flex items-center gap-8 text-sm font-medium text-white/60"
		>
			<!-- COMMENTED: Home link removed
			<a href="https://koreshield.com" class="hover:text-electric-blue transition-colors">Home</a>
			-->
			<a
				href="https://docs.koreshield.com"
				class="hover:text-electric-blue transition-colors"
				target="_blank"
				rel="noreferrer"
			>
				Docs
			</a>
			<a
				href="https://koreshield.com/pricing"
				class="hover:text-electric-blue transition-colors"
			>
				Pricing
			</a>
			<!-- COMMENTED: Contact button removed
			<a href="https://koreshield.com/#contact" class="hover:bg-electric-blue hover:text-white border border-electric-blue/40 text-electric-blue px-4 py-1.5 rounded-lg transition-colors">Contact</a>
			-->
		</div>

		<!-- Mobile Menu Button -->
		<button
			id="mobile-menu-btn"
			class="md:hidden p-2 text-white/60 hover:text-white transition-colors"
			aria-label="Open menu"
		>
			<svg
				xmlns="http://www.w3.org/2000/svg"
				width="24"
				height="24"
				viewBox="0 0 24 24"
				fill="none"
				stroke="currentColor"
				stroke-width="2"
				stroke-linecap="round"
				stroke-linejoin="round"
			>
				<line x1="3" y1="12" x2="21" y2="12"></line>
				<line x1="3" y1="6" x2="21" y2="6"></line>
				<line x1="3" y1="18" x2="21" y2="18"></line>
			</svg>
		</button>
	</div>
</header>

<!-- Mobile Menu -->
<div
	id="mobile-menu"
	class="md:hidden fixed inset-0 bg-[#050a14] z-[60] transition-all duration-300 ease-in-out opacity-0 translate-x-full pointer-events-none"
>
	<!-- Mobile menu header -->
	<div class="flex items-center justify-between px-6 py-6">
		<a href="/" class="flex items-center gap-2">
			<img
				src="/logo-white.svg"
				alt="KoreShield Logo"
				class="w-10"
			/>
		</a>
		<button
			id="mobile-menu-close"
			class="p-2 text-white/60 hover:text-white transition-colors"
			aria-label="Close menu"
		>
			<svg
				xmlns="http://www.w3.org/2000/svg"
				width="24"
				height="24"
				viewBox="0 0 24 24"
				fill="none"
				stroke="currentColor"
				stroke-width="2"
				stroke-linecap="round"
				stroke-linejoin="round"
			>
				<line x1="18" y1="6" x2="6" y2="18"></line>
				<line x1="6" y1="6" x2="18" y2="18"></line>
			</svg>
		</button>
	</div>

	<div class="flex flex-col h-[calc(100%-80px)] px-6 pb-8">
		<div class="flex flex-col gap-2 flex-1">
			<!-- COMMENTED: Home link removed
			<a href="https://koreshield.com" class="text-white/80 hover:text-white transition-colors py-4 text-2xl font-medium border-b border-white/10">Home</a>
			-->
			<a
				href="https://docs.koreshield.com"
				target="_blank"
				rel="noreferrer"
				class="text-white/80 hover:text-white transition-colors py-4 text-2xl font-medium border-b border-white/10"
			>
				Documentation
			</a>
			<a
				href="https://koreshield.com/pricing"
				class="text-white/80 hover:text-white transition-colors py-4 text-2xl font-medium border-b border-white/10"
			>
				Pricing
			</a>
			<!-- COMMENTED: Contact link removed
			<a href="https://koreshield.com/#contact" class="text-white/80 hover:text-white transition-colors py-4 text-2xl font-medium border-b border-white/10">Contact</a>
			-->
			<!-- COMMENTED: GitHub removed from mobile menu -->
			<!-- <a
				href="https://github.com/koreshield"
				target="_blank"
				rel="noopener noreferrer"
				class="flex items-center gap-3 text-white/80 hover:text-white transition-colors py-4 text-2xl font-medium border-b border-white/10"
			>
				GitHub
			</a> -->
		</div>
	</div>
</div>

<script>
	// Mobile menu functionality
	const mobileMenuBtn = document.getElementById("mobile-menu-btn");
	const mobileMenu = document.getElementById("mobile-menu");
	const mobileMenuClose = document.getElementById("mobile-menu-close");

	function openMobileMenu() {
		if (mobileMenu) {
			mobileMenu.classList.remove(
				"opacity-0",
				"translate-x-full",
				"pointer-events-none",
			);
			mobileMenu.classList.add(
				"opacity-100",
				"translate-x-0",
			);
			document.body.style.overflow = "hidden";
		}
	}

	function closeMobileMenu() {
		if (mobileMenu) {
			mobileMenu.classList.add(
				"opacity-0",
				"translate-x-full",
				"pointer-events-none",
			);
			mobileMenu.classList.remove(
				"opacity-100",
				"translate-x-0",
			);
			document.body.style.overflow = "";
		}
	}

	mobileMenuBtn?.addEventListener("click", openMobileMenu);
	mobileMenuClose?.addEventListener("click", closeMobileMenu);

	// Close menu when clicking on links
	const mobileLinks = mobileMenu?.querySelectorAll("a");
	mobileLinks?.forEach((link) => {
		link.addEventListener("click", closeMobileMenu);
	});
</script>
