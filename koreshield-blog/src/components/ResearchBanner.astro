---
const researchLink =
    "https://www.academia.edu/145685538/_Preprint_LLM_Firewall_A_Novel_Taxonomy_of_Indirect_Prompt_Injection_Attacks_in_Enterprise_RAG_Systems";
---

<div
    class="w-full relative overflow-hidden rounded-2xl border border-white/10 bg-deep-navy/50 backdrop-blur-md group my-16"
>
    <!-- Glow Effects -->
    <div
        class="absolute top-0 right-0 w-64 h-64 bg-electric-blue/10 rounded-full blur-[80px] -translate-y-1/2 translate-x-1/2 group-hover:bg-electric-blue/20 transition-colors duration-500"
    >
    </div>
    <div
        class="absolute bottom-0 left-0 w-48 h-48 bg-cyber-purple/10 rounded-full blur-[60px] translate-y-1/2 -translate-x-1/2 group-hover:bg-cyber-purple/20 transition-colors duration-500"
    >
    </div>

    <div
        class="relative z-10 grid md:grid-cols-[1fr_auto] gap-8 items-center p-8 md:p-10"
    >
        <!-- Content -->
        <div class="text-left">
            <div
                class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-electric-blue/10 text-electric-blue text-xs font-mono mb-4 border border-electric-blue/20"
            >
                <span class="relative flex h-2 w-2">
                    <span
                        class="animate-ping absolute inline-flex h-full w-full rounded-full bg-electric-blue opacity-75"
                    ></span>
                    <span
                        class="relative inline-flex rounded-full h-2 w-2 bg-electric-blue"
                    ></span>
                </span>
                RESEARCH PAPER
            </div>
            <h2
                class="text-2xl md:text-4xl font-bold text-white mb-4 leading-tight font-sans"
            >
                Explore AI security with the <br class="hidden md:block" />
                <span
                    class="text-transparent bg-clip-text bg-gradient-to-r from-electric-blue to-cyber-purple"
                >
                    LLM Firewall Research Paper
                </span>
            </h2>
            <p class="text-gray-400 max-w-xl text-lg mb-8 leading-relaxed">
                Discover our novel taxonomy of indirect prompt injection attacks
                in Enterprise RAG systems and learn how to defend your AI
                infrastructure.
            </p>

            <a
                href={researchLink}
                target="_blank"
                class="inline-flex items-center gap-2 px-6 py-3 bg-white text-deep-navy rounded-lg font-bold hover:bg-gray-100 transition-all hover:scale-105 hover:shadow-[0_0_20px_rgba(255,255,255,0.3)]"
            >
                Read the Paper
                <svg
                    xmlns="http://www.w3.org/2000/svg"
                    class="h-4 w-4"
                    viewBox="0 0 20 20"
                    fill="currentColor"
                >
                    <path
                        fill-rule="evenodd"
                        d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z"
                        clip-rule="evenodd"></path>
                </svg>
            </a>
        </div>

        <!-- Visual (Mock Book/Paper) -->
        <div class="hidden md:block relative perspective-1000">
            <div
                class="relative w-48 h-64 bg-gradient-to-br from-slate-900 to-deep-navy rounded-lg border border-white/10 shadow-2xl skew-y-3 skew-x-2 transform transition-transform group-hover:rotate-2 group-hover:scale-105 duration-500 flex items-center justify-center overflow-hidden"
            >
                <!-- Cover Design -->
                <div class="absolute inset-0 bg-noise opacity-30"></div>
                <div
                    class="absolute top-0 right-0 w-full h-full bg-gradient-to-bl from-white/5 to-transparent"
                >
                </div>

                <div class="text-center p-4">
                    <div
                        class="w-12 h-12 mx-auto bg-electric-blue rounded-lg flex items-center justify-center mb-4 shadow-lg text-white"
                    >
                        <svg
                            xmlns="http://www.w3.org/2000/svg"
                            class="h-6 w-6"
                            fill="none"
                            viewBox="0 0 24 24"
                            stroke="currentColor"
                        >
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"
                            ></path>
                        </svg>
                    </div>
                    <div
                        class="text-[0.6rem] uppercase tracking-widest text-electric-blue font-mono mb-1"
                    >
                        Preprint
                    </div>
                    <div
                        class="text-white font-bold text-lg leading-tight mb-2"
                    >
                        LLM Firewall
                    </div>
                    <div class="w-8 h-1 bg-cyber-purple mx-auto rounded-full">
                    </div>
                </div>
            </div>
            <!-- Shadow Element -->
            <div
                class="absolute -bottom-6 left-4 w-48 h-8 bg-black/50 blur-[20px] rounded-full skew-x-12"
            >
            </div>
        </div>
    </div>
</div>
