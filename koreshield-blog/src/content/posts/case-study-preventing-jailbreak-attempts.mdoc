### Phase 2: KoreShield Integration (Week 3-4)

The team integrated KoreShield as a security layer between their application and OpenAI:

```python
from koreshield import KoreShieldClient
import os

# Initialize KoreShield client
koreshield_client = KoreShieldClient(
    api_key=os.getenv("KORESHIELD_API_KEY"),
    base_url="https://api.koreshield.com"
)

# Configure security policies
SECURITY_POLICY = {
    "sensitivity": "high",  # Financial services requires highest protection
    "default_action": "block",  # Block on detection
    "features": {
        "sanitization": True,
        "detection": True,
        "policy_enforcement": True,
        "output_filtering": True
    },
    "custom_rules": [
        {
            "name": "block_customer_data_requests",
            "pattern": r"customer\s+(database|data|information|records)",
            "action": "block",
            "severity": "critical"
        },
        {
            "name": "block_compliance_bypasses",
            "pattern": r"(ignore|bypass|override)\s+(compliance|policy|rules)",
            "action": "block",
            "severity": "critical"
        }
    ]
}

async def protected_llm_call(user_id: str, prompt: str, context: list = None):
    """
    Protected LLM call with comprehensive jailbreak prevention.
    """
    try:
        # Step 1: Scan user input
        scan_result = await koreshield_client.scan_prompt(
            prompt=prompt,
            user_id=user_id,
            policy=SECURITY_POLICY
        )
        
        # Step 2: Check threat level
        if scan_result.threat_level in ["high", "critical"]:
            # Log security event
            await log_security_event({
                "type": "jailbreak_blocked",
                "user_id": user_id,
                "threat_type": scan_result.threat_type,
                "confidence": scan_result.confidence,
                "prompt_sample": prompt[:100]
            })
            
            # Return safe error message
            return {
                "error": "Your request could not be processed due to security concerns.",
                "error_code": "SECURITY_VIOLATION",
                "support_ticket": generate_ticket_id()
            }
        
        # Step 3: If safe, proceed with LLM call
        response = await openai_client.chat.completions.create(
            model="gpt-4",
            messages=[
                {"role": "system", "content": SYSTEM_PROMPT},
                *context,
                {"role": "user", "content": scan_result.sanitized_prompt}
            ]
        )
        
        # Step 4: Scan output for data leakage
        output_text = response.choices[0].message.content
        output_scan = await koreshield_client.scan_prompt(output_text)
        
        if output_scan.contains_pii or output_scan.contains_sensitive_data:
            # Redact sensitive information
            output_text = output_scan.redacted_text
            
            await log_security_event({
                "type": "output_filtered",
                "user_id": user_id,
                "findings": output_scan.findings
            })
        
        return {
            "response": output_text,
            "security_metadata": {
                "input_threat_level": scan_result.threat_level,
                "output_filtered": output_scan.was_filtered
            }
        }
        
    except Exception as e:
        await log_error({
            "type": "llm_call_failed",
            "user_id": user_id,
            "error": str(e)
        })
        raise
```

### Phase 3: Monitoring and Tuning (Week 5-8)

The team deployed comprehensive monitoring dashboards:

```python
class SecurityDashboard:
    def __init__(self):
        self.metrics = {
            "total_requests": 0,
            "blocked_requests": 0,
            "warned_requests": 0,
            "attacks_by_type": defaultdict(int),
            "attacks_by_user": defaultdict(int),
            "false_positives": 0
        }
    
    async def track_request(self, user_id: str, result: dict):
        """Track request through security pipeline."""
        self.metrics["total_requests"] += 1
        
        if result.get("blocked"):
            self.metrics["blocked_requests"] += 1
            self.metrics["attacks_by_type"][result["threat_type"]] += 1
            self.metrics["attacks_by_user"][user_id] += 1
        elif result.get("warned"):
            self.metrics["warned_requests"] += 1
    
    def get_statistics(self) -> dict:
        """Get security statistics."""
        total = self.metrics["total_requests"]
        blocked = self.metrics["blocked_requests"]
        
        return {
            "total_requests": total,
            "blocked_requests": blocked,
            "block_rate": blocked / total if total > 0 else 0,
            "top_attack_types": dict(
                sorted(
                    self.metrics["attacks_by_type"].items(),
                    key=lambda x: x[1],
                    reverse=True
                )[:10]
            ),
            "top_attacking_users": dict(
                sorted(
                    self.metrics["attacks_by_user"].items(),
                    key=lambda x: x[1],
                    reverse=True
                )[:10]
            )
        }

# Initialize dashboard
dashboard = SecurityDashboard()

# Track all requests
await dashboard.track_request(user_id, scan_result)
```

